# Core runtime
DATABASE_URL=postgresql://user:password@host/database
NEXTAUTH_URL=https://your-domain.example
NEXTAUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
APP_NAME=Vahi Hospital OS
HOSPITAL_NAME=Vahi Hospital
BOOTSTRAP_SUPER_ADMIN_EMAILS=owner@your-domain.example
BOOTSTRAP_ADMIN_EMAILS=

# Upload storage
# auto = prefer R2 if configured, then S3, else local
UPLOAD_STORAGE_DRIVER=auto
UPLOAD_PUBLIC_BASE_URL=/uploads

# AWS S3
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false

# Cloudflare R2
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# Communications
COMMUNICATION_EMAIL_PROVIDER=NONE
COMMUNICATION_SMS_PROVIDER=NONE
COMMUNICATION_WHATSAPP_PROVIDER=NONE
RESEND_API_KEY=
RESEND_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
